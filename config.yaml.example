# ============================================================
# 今日热闻 - 邮件推送配置（示例）
# 复制此文件为 config.yaml 并填入你的信息
# ============================================================

# ---------- 邮件发送配置 (SMTP) ----------
mail:
  # SMTP 服务器地址
  #   QQ邮箱:   smtp.qq.com          (需开启SMTP服务 + 授权码)
  #   Gmail:    smtp.gmail.com       (需开启App Passwords)
  #   163邮箱:  smtp.163.com         (需开启SMTP服务 + 授权码)
  #   Outlook:  smtp.office365.com
  smtp_server: "smtp.qq.com"
  smtp_port: 465                     # 465=SSL, 587=TLS

  # 发件人邮箱地址
  sender_email: "your_email@qq.com"
  # SMTP 授权码（不是登录密码！）
  sender_password: "your_auth_code"

  # 收件人列表（支持多个）
  recipients:
    - "your_email@qq.com"

  # 发件人显示名称
  sender_name: "今日热闻"

# ---------- 推送内容开关 ----------
content:
  weibo: true        # 微博热搜
  zhihu: true        # 知乎热搜
  baidu: false       # 百度热搜
  limit: 20          # 每个来源显示前 N 条

# ---------- 定时设置 ----------
schedule:
  enabled: true      # 是否启用定时发送
  times:
    - "08:00"        # 早报
    - "19:00"        # 晚报
